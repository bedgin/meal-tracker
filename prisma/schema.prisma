// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  ingredients Ingredient[]
  foods       Food[]
  recipes     Recipe[]
  meals       Meal[]
  goals       Goal[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Ingredient {
  id                   String   @id @default(cuid())
  userId               String
  name                 String
  servingMeasureAmount Float?
  servingMeasureUnit   String?  // cups, tbsp, tsp
  servingWeightAmount  Float?
  servingWeightUnit    String?  // lb, oz, g
  caloriesPerServing   Float
  proteinPerServing    Float
  isFavorite           Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipeIngredients RecipeIngredient[]
}

model Food {
  id                   String   @id @default(cuid())
  userId               String
  name                 String
  servingMeasureAmount Float?
  servingMeasureUnit   String?  // cups, tbsp, tsp, items
  servingWeightAmount  Float?
  servingWeightUnit    String?  // lb, oz, g
  caloriesPerServing   Float
  proteinPerServing    Float
  isFavorite           Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealItems MealItem[]
}

model Recipe {
  id           String   @id @default(cuid())
  userId       String
  name         String
  servings     Int      @default(1)
  instructions String?  @db.Text
  isFavorite   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredients RecipeIngredient[]
  mealItems   MealItem[]
}

model RecipeIngredient {
  id           String  @id @default(cuid())
  recipeId     String
  ingredientId String
  amountMeasure Float?
  measureUnit   String?
  amountWeight  Float?
  weightUnit    String?

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
}

model Meal {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  time      DateTime
  mealType  String   // Breakfast, Lunch, Dinner, Snack
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealItems MealItem[]
}

model MealItem {
  id                String  @id @default(cuid())
  mealId            String
  itemType          String  // food | recipe
  foodId            String?
  recipeId          String?
  servingsMultiplier Float   @default(1)
  caloriesSnapshot  Float
  proteinSnapshot   Float

  meal   Meal    @relation(fields: [mealId], references: [id], onDelete: Cascade)
  food   Food?   @relation(fields: [foodId], references: [id])
  recipe Recipe? @relation(fields: [recipeId], references: [id])
}

model Goal {
  id            String   @id @default(cuid())
  userId        String
  date          DateTime @db.Date
  calorieGoal   Float?
  proteinGoal   Float?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}
